# Global ignores for BigBum monorepo

# OS/editor
.DS_Store
Thumbs.db
.idea/
.vscode/

# Environment files
.env
.env.*
!.env.example

# Dependency/build caches
**/node_modules/
**/dist/
**/build/
**/.dart_tool/
**/.pub-cache/
**/.flutter-plugins
**/.flutter-plugins-dependencies

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Sensitive artifacts and keys
**/id_rsa
**/*.pem
**/*.key
bigbum-be/src/sample/chatgptReturn.json
